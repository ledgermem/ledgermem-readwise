{
  "name": "@mnemo/readwise",
  "version": "0.1.0",
  "description": "Pull Readwise highlights into Mnemo on a schedule.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "getmnemo-readwise": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js sync",
    "dev": "tsx src/cli.ts sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "keywords": ["readwise", "highlights", "getmnemo", "memory"],
  "author": "Mnemo <founders@getmnemo.xyz>",
  "license": "MIT",
  "dependencies": {
    "@mnemo/memory": "^0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
